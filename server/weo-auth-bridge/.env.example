# Port the bridge listens on.
PORT=8787

# Base URL of your New API instance (the Anthropic/OpenAI-compatible relay).
NEW_API_BASE_URL=https://api.weo.asia

# Public URL of THIS bridge, as reachable from users' browsers. Used to build
# the device verification link. With the nginx example this is the /bridge path.
PUBLIC_BASE_URL=https://api.weo.asia/bridge

# Device-code lifetime and CLI poll interval (seconds).
DEVICE_CODE_TTL_SEC=600
POLL_INTERVAL_SEC=5
